# ── Telegram Bot (MAJBURIY) ───────────────────────────────────────────────────
# @BotFather dan olinadi
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# my.telegram.org dan olinadi (Pyrogram uchun — katta fayllar)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ── Local Bot API Server (IXTIYORIY) ─────────────────────────────────────────
# Railway da Local Bot API ishlatilsa (2GB+ fayllar):
# Railway da "local-bot-api" service qo'shing va shu URL ni ko'rsating
# LOCAL_BOT_API_URL=http://local-bot-api.railway.internal:8081/bot

# ── Cloudflare R2 (IXTIYORIY) ────────────────────────────────────────────────
# R2 Bulut saqlash — faqat R2 funksiyasidan foydalanilsa kerak
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET_NAME=your_bucket_name
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Ma'lumotlar papkasi (Railway Volume) ─────────────────────────────────────
# Railway da Volume /data ga mount qilish ZARUR (session va DB uchun)
# Kod avtomatik /data ni aniqlaydi — bu o'zgaruvchini o'rnatish shart emas
# DATA_DIR=/data
